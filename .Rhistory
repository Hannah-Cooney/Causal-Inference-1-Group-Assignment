install.packages("stdReg")
library(stdReg)
# Load the data
load(file = "rhc_exercise.Rdata")
colnames(rhc)
rhc$treatment
hist(rhc$treatment)
sum(rhc$treatment == "no RHC")
sum(rhc$treatment == "RHC")
# Load the data
load(file = "rhc_exercise.Rdata")
# Examine the frequency of RHC
sum(rhc$treatment == "no RHC")
sum(rhc$treatment == "RHC")
rhc$death30
# Examine the frequency of death30
sum(rhc$death30 == "alive")
sum(rhc$death30 == "death") #
# Logistic regression model
model_1 <- glm(treatment ~ death30, family = "binomial", data = rhc)
