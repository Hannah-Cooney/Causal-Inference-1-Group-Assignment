cor_matrix <- cor(data[, ], method = "pearson")
cor_matrix <- cor(obesity[, colnames(obesity)], method = "pearson")
cor.test(obesity$SYSBP, obesity$SYSBP, method = "pearson")
cor.test(obesity$SYSBP, obesity$DIABP, method = "pearson")
# Test correlations for blood pressure and substance use
cor.test(obesity$SYSBP, obesity$DIABP, method = "pearson")
cor.test(obesity$alcohol, obesity$current.smoking, method = "pearson")
