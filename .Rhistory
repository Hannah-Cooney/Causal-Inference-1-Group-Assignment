knitr::opts_chunk$set(echo = TRUE)
library(dplyr)
library(dagitty)
library(ggplot2)
library(GGally)
library(gridExtra)
# Load the data
load("obesity.Rda")
obesity <- obesity |>
mutate(diabetes = ifelse(diabetes == "No", 0, 1)) |>
select(-c("nr", "medstatin", "medglucose", "CVD",
"MI", "angina", "stroke", "death"))
obesity_na <- obesity |>
filter(diabetes != "NA") |> # We only look at obesity
na.omit() # Remove rows with NA value in any column
# Test correlations for blood pressure
cor.test(obesity$SYSBP, obesity$DIABP, method = "pearson")
# Test correlation for substance abuse
#cor_result <- anova(alcohol ~ current.smoking, data = data)
#summary(cor_result)
# Specify the DAG
g.diabetes <- dagitty('dag {
education     [pos="-1, -2"]
income        [pos="-2.5, 0"]
alcohol       [pos="-1, 3"]
current.smoking [pos="-2.5, 3"]
sex           [pos="1, -2"]
medhyper      [pos="0, 3"]
bmi           [pos="2, -1"]
waist         [pos="1, 0"]
age           [pos="1.5, 1.5"]
SYSBP         [pos="-0.5, 1"]
DIABP         [pos="-1.5, 1.5"]
diabetes      [outcome,pos="-0.5, -0.5"]
education -> {income}
income -> diabetes
sex -> {diabetes bmi}
medhyper -> {SYSBP DIABP}
bmi -> waist
waist -> diabetes
age -> {bmi SYSBP DIABP}
alcohol -> {SYSBP DIABP}
SYSBP -> diabetes
DIABP -> diabetes
BP -> {SYSBP DIABP}
}
')
# Plot the DAG
plot(g.diabetes)
# Specify the DAG
g.diabetes <- dagitty('dag {
education     [pos="-1, -2"]
income        [pos="-2.5, 0"]
alcohol       [pos="-1, 3"]
current.smoking [pos="-2.5, 3"]
sex           [pos="1, -2"]
